{
  "expo": {
    "name": "Brasil em Foco",
    "slug": "brasil-em-foco",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "brasilemfoco",
    "userInterfaceStyle": "light",
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#009C3B"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.ufrpe.brasilemfoco"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#009C3B"
      },
      "package": "com.ufrpe.brasilemfoco"
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      [
        "expo-router",
        {
          "root": "./src/app"
        }
      ],
      "expo-asset"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
